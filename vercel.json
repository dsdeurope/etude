{
  "version": 2,
  "buildCommand": "NODE_OPTIONS='--openssl-legacy-provider' SKIP_PREFLIGHT_CHECK=true yarn build",
  "outputDirectory": "build", 
  "installCommand": "yarn install",
  "framework": "create-react-app",
  "functions": {
    "api/health.py": {
      "runtime": "python3.9"
    },
    "api/enrich-concordance.py": {
      "runtime": "python3.9"
    },
    "api/generate-character-history.py": {
      "runtime": "python3.9"
    }
  },
  "env": {
    "SKIP_PREFLIGHT_CHECK": "true",
    "NODE_OPTIONS": "--openssl-legacy-provider"
  },
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health.py"
    },
    {
      "source": "/api/enrich-concordance", 
      "destination": "/api/enrich-concordance.py"
    },
    {
      "source": "/api/generate-character-history",
      "destination": "/api/generate-character-history.py"
    },
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}