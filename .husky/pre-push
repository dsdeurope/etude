#!/usr/bin/env sh
set -e

# 0) Panic button
[ -n "$SKIP_PREPUSH_BUILD" ] && { echo "[pre-push] SKIP_PREPUSH_BUILD=1 -> skip"; exit 0; }

# 1) Seulement sur main
BRANCH="$(git rev-parse --abbrev-ref HEAD)"
[ "$BRANCH" != "main" ] && { echo "[pre-push] $BRANCH != main -> skip build"; exit 0; }

# 2) Détecter les changements côté CRA
UPSTREAM="$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo)"
RANGE="${UPSTREAM:-HEAD~1}..HEAD"
PATTERN='^NOUVEAU_DEPLOIEMENT_VERCEL/(src|public|package\.json|yarn\.lock|vercel\.json|\.prettier.*|\.eslint.*)'

if git diff --name-only "$RANGE" | grep -qE "$PATTERN"; then
  echo "[pre-push] CRA changes on main -> lint & build"
  cd NOUVEAU_DEPLOIEMENT_VERCEL || exit 1

  # Prettier doit être clean (utilise le script du sous-projet)
  yarn -s format:check

  # ESLint si dispo localement (n'installe rien)
  if npx --no-install eslint -v >/dev/null 2>&1; then
    npx eslint --max-warnings=0 "src/**/*.{js,jsx}"
  else
    echo "[pre-push] eslint CLI not found -> skip ESLint check"
  fi

  # Build CRA en prod (silencieux)
  yarn -s build
else
  echo "[pre-push] No CRA changes -> skip build"
fi
